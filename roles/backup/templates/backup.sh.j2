#!/usr/bin/env bash
# {{ ansible_managed }}
# OpenOctopus backup script — generated by Ansible
#
# Backs up SQLite database and JSONL session files.

set -euo pipefail

TIMESTAMP=$(date +%Y%m%d-%H%M%S)
BACKUP_DIR="{{ backup_dir }}"
DATA_DIR="{{ openoctopus_data_dir }}"
SESSIONS_DIR="{{ openoctopus_sessions_dir }}"
BACKUP_NAME="openoctopus-backup-${TIMESTAMP}"
BACKUP_PATH="${BACKUP_DIR}/${BACKUP_NAME}"
RETENTION_DAYS="{{ backup_retention_days }}"

echo "[$(date -Iseconds)] Starting OpenOctopus backup..."

# Create temporary backup directory
mkdir -p "${BACKUP_PATH}"

# Backup SQLite database using .backup command (safe for concurrent access)
if [ -f "${DATA_DIR}/openoctopus.db" ]; then
    echo "[$(date -Iseconds)] Backing up SQLite database..."
    sqlite3 "${DATA_DIR}/openoctopus.db" ".backup '${BACKUP_PATH}/openoctopus.db.bak'"
    echo "[$(date -Iseconds)] Database backup complete."
else
    echo "[$(date -Iseconds)] WARNING: Database file not found at ${DATA_DIR}/openoctopus.db"
fi

# Backup JSONL session files
if [ -d "${SESSIONS_DIR}" ]; then
    echo "[$(date -Iseconds)] Backing up session files..."
    cp -r "${SESSIONS_DIR}" "${BACKUP_PATH}/sessions"
    echo "[$(date -Iseconds)] Session backup complete."
else
    echo "[$(date -Iseconds)] WARNING: Sessions directory not found at ${SESSIONS_DIR}"
fi

# Create compressed archive
echo "[$(date -Iseconds)] Compressing backup..."
tar -czf "${BACKUP_DIR}/${BACKUP_NAME}.tar.gz" -C "${BACKUP_DIR}" "${BACKUP_NAME}"
rm -rf "${BACKUP_PATH}"
echo "[$(date -Iseconds)] Archive created: ${BACKUP_DIR}/${BACKUP_NAME}.tar.gz"

{% if backup_s3_enabled | default(false) | bool %}
# Upload to S3
if command -v aws &> /dev/null; then
    echo "[$(date -Iseconds)] Uploading to S3: s3://{{ backup_s3_bucket }}/..."
    aws s3 cp "${BACKUP_DIR}/${BACKUP_NAME}.tar.gz" \
        "s3://{{ backup_s3_bucket }}/${BACKUP_NAME}.tar.gz"
    echo "[$(date -Iseconds)] S3 upload complete."
else
    echo "[$(date -Iseconds)] WARNING: awscli not found, skipping S3 upload."
fi
{% endif %}

# Cleanup old backups
echo "[$(date -Iseconds)] Cleaning up backups older than ${RETENTION_DAYS} days..."
find "${BACKUP_DIR}" -name "openoctopus-backup-*.tar.gz" -type f -mtime "+${RETENTION_DAYS}" -delete
echo "[$(date -Iseconds)] Cleanup complete."

echo "[$(date -Iseconds)] Backup finished: ${BACKUP_DIR}/${BACKUP_NAME}.tar.gz"
