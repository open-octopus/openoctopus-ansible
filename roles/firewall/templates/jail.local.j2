# {{ ansible_managed }}
# Fail2ban jail configuration — generated by Ansible

[DEFAULT]
bantime  = {{ fail2ban_bantime }}
findtime = {{ fail2ban_findtime }}
maxretry = {{ fail2ban_maxretry }}

[sshd]
enabled  = true
port     = {{ ufw_ssh_port }}
filter   = sshd
logpath  = /var/log/auth.log
backend  = systemd
