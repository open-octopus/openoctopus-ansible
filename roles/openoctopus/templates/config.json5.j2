// {{ ansible_managed }}
// OpenOctopus configuration — generated by Ansible
{
  // LLM Providers
  llm: {
    providers: [
{% if anthropic_api_key | default('') | length > 0 %}
      {
        id: "anthropic",
        type: "anthropic",
        apiKey: "{{ anthropic_api_key }}",
        priority: 1,
      },
{% endif %}
{% if openai_api_key | default('') | length > 0 %}
      {
        id: "openai",
        type: "openai",
        apiKey: "{{ openai_api_key }}",
        priority: 2,
      },
{% endif %}
{% if google_api_key | default('') | length > 0 %}
      {
        id: "google",
        type: "google",
        apiKey: "{{ google_api_key }}",
        priority: 3,
      },
{% endif %}
{% if ollama_url | default('') | length > 0 %}
      {
        id: "ollama",
        type: "ollama",
        baseUrl: "{{ ollama_url }}",
        priority: 10,
      },
{% endif %}
    ],
  },

  // Storage
  storage: {
    type: "sqlite",
    database: "/app/data/openoctopus.db",
    sessionsDir: "/app/data/sessions",
  },

  // Gateway
  gateway: {
    ws: {
      port: 19789,
    },
    http: {
      port: 19790,
    },
  },
}
