# {{ ansible_managed }}
# OpenOctopus Docker Compose — generated by Ansible

services:
  gateway:
    image: {{ openoctopus_image }}:{{ openoctopus_version }}
    container_name: openoctopus-gateway
    restart: unless-stopped
    ports:
      - "{{ openoctopus_ws_port }}:19789"
      - "{{ openoctopus_http_port }}:19790"
    volumes:
      - {{ openoctopus_data_dir }}:/app/data
      - {{ openoctopus_sessions_dir }}:/app/data/sessions
      - {{ openoctopus_config_dir }}/config.json5:/app/config/config.json5:ro
    environment:
{% if anthropic_api_key | default('') | length > 0 %}
      ANTHROPIC_API_KEY: "{{ anthropic_api_key }}"
{% endif %}
{% if openai_api_key | default('') | length > 0 %}
      OPENAI_API_KEY: "{{ openai_api_key }}"
{% endif %}
{% if google_api_key | default('') | length > 0 %}
      GOOGLE_API_KEY: "{{ google_api_key }}"
{% endif %}
{% if ollama_url | default('') | length > 0 %}
      OLLAMA_URL: "{{ ollama_url }}"
{% endif %}
      NODE_ENV: production
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:19790/healthz"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
